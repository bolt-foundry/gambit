{
  "name": "@bolt-foundry/browser-runtime",
  "version": "0.1.0",
  "exports": {
    ".": "./mod.ts",
    "./browser-cli": "./src/browserCliMain.ts",
    "./bin/bft-browser": "./bin/bft-browser.ts",
    "./src/appTargets.ts": "./src/appTargets.ts",
    "./src/automation/timeline.ts": "./src/automation/timeline.ts",
    "./src/browserRuntime.ts": "./src/browserRuntime.ts",
    "./src/config.ts": "./src/config.ts",
    "./src/e2e/utils.ts": "./src/e2e/utils.ts",
    "./src/graphqlMocks.ts": "./src/graphqlMocks.ts",
    "./src/liveControl.ts": "./src/liveControl.ts",
    "./src/paths.ts": "./src/paths.ts",
    "./src/runner.ts": "./src/runner.ts",
    "./src/runnerTypes.ts": "./src/runnerTypes.ts",
    "./src/server.ts": "./src/server.ts",
    "./src/utils.ts": "./src/utils.ts"
  },
  "imports": {
    "@std/cli": "jsr:@std/cli@^1.0.22",
    "@std/fs": "jsr:@std/fs@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.1",
    "playwright-core": "npm:playwright-core@^1.57.0"
  },
  "tasks": {
    "fmt": "deno fmt",
    "lint": "deno lint",
    "demo:ui-video": "deno run -A src/run-gambit-demo.ts",
    "demo:verify": "deno run -A src/run-gambit-verify-demo.ts",
    "demo:graphiql": "deno run -A src/run-gambit-graphiql-demo.ts",
    "demo:workspace-scaffold": "deno run -A src/run-gambit-workspace-scaffold-demo.ts",
    "demo:faq-chat": "deno run -A src/run-gambit-faq-chat-demo.ts",
    "demo:canonical": "deno run -A src/run-gambit-canonical-demo.ts",
    "demo:sandbox-serve": "deno run -A src/run-gambit-sandbox-serve.ts"
  },
  "fmt": {
    "exclude": ["dist"]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
